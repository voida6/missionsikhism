---
// Renders "Last updated" from Git for a content file (Phase H). Build-time only;
// if git is unavailable (or the file is untracked) it renders nothing rather
// than breaking the build.
interface Props { path: string }
const { path } = Astro.props;

let iso: string | null = null;
try {
  const { execFileSync } = await import('node:child_process');
  const out = execFileSync('git', ['log', '-1', '--format=%cs', '--', path], {
    encoding: 'utf8',
    stdio: ['ignore', 'pipe', 'ignore'],
  }).trim();
  if (/^\d{4}-\d{2}-\d{2}$/.test(out)) iso = out;
} catch {
  iso = null;
}
const label = iso
  ? new Date(iso + 'T00:00:00Z').toLocaleDateString('en-GB', {
      year: 'numeric', month: 'long', day: 'numeric',
    })
  : null;
---
{label && <p class="last-updated">Last updated: <time datetime={iso}>{label}</time></p>}
