---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Optional absolute or root-relative image for social cards. */
  image?: string;
}

const { title, description, image } = Astro.props;

// Canonical + social URLs are absolute, resolved against `site` in astro.config.mjs.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ? new URL(image, Astro.site).href : undefined;
const siteName = 'Mission Sikhism';

// Navigation is config-driven (02-NAVIGATION-IA): three flat lenses first, then
// grouped menus. Groups render as accessible <details> dropdowns on desktop and
// expandable sections on mobile — the same markup reused at both sizes.
type NavItem = { label: string; href: string };
type NavGroup = { label: string; items: NavItem[] };
type NavEntry = NavItem | NavGroup;

const nav: NavEntry[] = [
  { label: 'History', href: '/history' },
  { label: 'Map', href: '/map' },
  { label: 'People', href: '/people' },
  {
    label: 'Learn',
    items: [
      { label: 'The Faith', href: '/faith' },
      { label: 'Culture & Heritage', href: '/culture' },
      { label: 'Glossary', href: '/glossary' },
      { label: 'Daily Prayers', href: '/nitnem' },
    ],
  },
  {
    label: 'Sources',
    items: [
      { label: 'Library', href: '/library' },
      { label: 'Books to Read', href: '/books' },
    ],
  },
  { label: 'About', href: '/about' },
];

const isGroup = (e: NavEntry): e is NavGroup => 'items' in e;

// Active-state: map the first path segment to the tab that owns it, so shared
// destinations (/events, /places) borrow History and Map respectively.
const path = Astro.url.pathname;
const seg = '/' + (path.split('/').filter(Boolean)[0] ?? '');
const ownerBySeg: Record<string, string> = {
  '/history': 'History',
  '/events': 'History',
  '/map': 'Map',
  '/places': 'Map',
  '/people': 'People',
  '/faith': 'Learn',
  '/culture': 'Learn',
  '/glossary': 'Learn',
  '/nitnem': 'Learn',
  '/library': 'Sources',
  '/books': 'Sources',
  '/about': 'About',
};
const activeTab = ownerBySeg[seg] ?? '';

// Site-wide structured data (Phase H): WebSite + SearchAction and Organization.
const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') : '';
const siteJsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: siteName,
    url: siteUrl + '/',
    potentialAction: {
      '@type': 'SearchAction',
      target: siteUrl + '/search?q={search_term_string}',
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: siteName,
    url: siteUrl + '/',
    description: 'A non-profit, fully-sourced history of the Sikh faith (1469 to today).',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#1e3a5f" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Mission Sikhism — new events" href="/rss.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(siteJsonld)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="container">
        <a class="brand" href="/">Mission Sikhism</a>
        <input id="nav-toggle" class="nav-toggle-cb" type="checkbox" hidden />

        <div class="header-actions">
          <a class="nav-search" href="/search" aria-label="Search">
            <span aria-hidden="true">🔍</span>
          </a>
          <label
            for="nav-toggle"
            class="nav-hamburger"
            aria-label="Menu"
            aria-expanded="false"
            role="button"
            tabindex="0"
          >
            <span aria-hidden="true">☰</span>
          </label>
        </div>

        <nav class="nav" id="primary-nav" aria-label="Primary">
          {
            nav.map((entry) =>
              isGroup(entry) ? (
                <details class="nav-group">
                  <summary aria-current={activeTab === entry.label ? 'true' : undefined}>
                    {entry.label}
                  </summary>
                  <ul class="nav-menu">
                    {entry.items.map((item) => (
                      <li>
                        <a
                          href={item.href}
                          aria-current={seg === item.href ? 'page' : undefined}
                        >
                          {item.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ) : (
                <a
                  href={entry.href}
                  aria-current={activeTab === entry.label ? 'page' : undefined}
                >
                  {entry.label}
                </a>
              )
            )
          }
          <a class="btn btn-primary nav-contribute" href="/about#contribute">
            Contribute →
          </a>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          Mission Sikhism — a non-profit, fully-sourced history of the Sikh
          faith. Every fact on this site is cited.
        </p>
        <nav class="footer-nav" aria-label="Footer">
          <a href="/history">History</a>
          <a href="/map">Map</a>
          <a href="/people">People</a>
          <a href="/faith">The Faith</a>
          <a href="/library">Library</a>
          <a href="/about">About</a>
          <a href="/about#contribute">Contribute</a>
          <a href="/rss.xml">RSS</a>
        </nav>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var toggle = document.getElementById('nav-toggle');
        var hamburger = document.querySelector('.nav-hamburger');
        var nav = document.getElementById('primary-nav');
        if (!toggle || !hamburger || !nav) return;

        // Mobile panel: keep aria-expanded in sync, trap focus, lock scroll.
        function firstLink() {
          return nav.querySelector('a, summary');
        }
        toggle.addEventListener('change', function () {
          var open = toggle.checked;
          hamburger.setAttribute('aria-expanded', open ? 'true' : 'false');
          document.body.style.overflow = open ? 'hidden' : '';
          if (open) {
            var f = firstLink();
            if (f) f.focus();
          }
        });
        // Let the hamburger label be toggled with Enter/Space (it is focusable).
        hamburger.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            toggle.checked = !toggle.checked;
            toggle.dispatchEvent(new Event('change'));
          }
        });
        function closeMenu() {
          if (toggle.checked) {
            toggle.checked = false;
            toggle.dispatchEvent(new Event('change'));
            hamburger.focus();
          }
        }
        // Close the mobile panel when a link inside it is followed.
        nav.addEventListener('click', function (e) {
          if (e.target.closest('a') && toggle.checked) closeMenu();
        });

        // Desktop dropdowns: open on hover, close on outside-click and Esc.
        var groups = Array.prototype.slice.call(nav.querySelectorAll('.nav-group'));
        var hoverCapable = window.matchMedia('(hover: hover) and (min-width: 761px)');
        groups.forEach(function (g) {
          g.addEventListener('mouseenter', function () {
            if (hoverCapable.matches) g.open = true;
          });
          g.addEventListener('mouseleave', function () {
            if (hoverCapable.matches) g.open = false;
          });
        });
        document.addEventListener('click', function (e) {
          groups.forEach(function (g) {
            if (g.open && !g.contains(e.target)) g.open = false;
          });
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') {
            groups.forEach(function (g) { g.open = false; });
            closeMenu();
          }
        });
      })();
    </script>
  </body>
</html>
