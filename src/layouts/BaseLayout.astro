---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Optional absolute or root-relative image for social cards. */
  image?: string;
}

const { title, description, image } = Astro.props;

// Canonical + social URLs are absolute, resolved against `site` in astro.config.mjs.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ? new URL(image, Astro.site).href : undefined;
const siteName = 'Mission Sikhism';

// Navigation is config-driven (02-NAVIGATION-IA): three flat lenses first, then
// grouped menus. Groups render as accessible <details> dropdowns on desktop and
// expandable sections on mobile — the same markup reused at both sizes.
type NavItem = { label: string; href: string };
type NavGroup = { label: string; items: NavItem[] };
type NavEntry = NavItem | NavGroup;

const nav: NavEntry[] = [
  { label: 'History', href: '/history' },
  { label: 'Map', href: '/map' },
  { label: 'People', href: '/people' },
  {
    label: 'Learn',
    items: [
      { label: 'The Faith', href: '/faith' },
      { label: 'Culture & Heritage', href: '/culture' },
      { label: 'Glossary', href: '/glossary' },
      { label: 'Daily Prayers', href: '/nitnem' },
    ],
  },
  {
    label: 'Sources',
    items: [
      { label: 'Library', href: '/library' },
      { label: 'Books to Read', href: '/books' },
    ],
  },
  { label: 'About', href: '/about' },
];

const isGroup = (e: NavEntry): e is NavGroup => 'items' in e;

// Active-state: map the first path segment to the tab that owns it, so shared
// destinations (/events, /places) borrow History and Map respectively.
const path = Astro.url.pathname;
const seg = '/' + (path.split('/').filter(Boolean)[0] ?? '');
const ownerBySeg: Record<string, string> = {
  '/history': 'History',
  '/events': 'History',
  '/map': 'Map',
  '/places': 'Map',
  '/people': 'People',
  '/faith': 'Learn',
  '/culture': 'Learn',
  '/glossary': 'Learn',
  '/nitnem': 'Learn',
  '/library': 'Sources',
  '/books': 'Sources',
  '/about': 'About',
};
const activeTab = ownerBySeg[seg] ?? '';

// Site-wide structured data (Phase H): WebSite + SearchAction and Organization.
const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') : '';
const siteJsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: siteName,
    url: siteUrl + '/',
    potentialAction: {
      '@type': 'SearchAction',
      target: siteUrl + '/search?q={search_term_string}',
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: siteName,
    url: siteUrl + '/',
    description: 'A non-profit, fully-sourced history of the Sikh faith (1469 to today).',
  },
];

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#faf8f3" />

    <!-- Theme: applied before first paint to avoid a flash of the wrong mode. -->
    <script is:inline>
      (function () {
        var t;
        try { t = localStorage.getItem('theme'); } catch (e) {}
        if (t !== 'light' && t !== 'dark') {
          t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Mission Sikhism — new events" href="/rss.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(siteJsonld)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="container">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">☬</span>
          Mission Sikhism
        </a>

        <input id="nav-toggle" class="nav-toggle-cb" type="checkbox" hidden />

        <nav class="nav" id="primary-nav" aria-label="Primary">
          {
            nav.map((entry) =>
              isGroup(entry) ? (
                <details class="nav-group">
                  <summary aria-current={activeTab === entry.label ? 'true' : undefined}>
                    {entry.label}
                  </summary>
                  <ul class="nav-menu">
                    {entry.items.map((item) => (
                      <li>
                        <a
                          href={item.href}
                          aria-current={seg === item.href ? 'page' : undefined}
                        >
                          {item.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ) : (
                <a
                  href={entry.href}
                  aria-current={activeTab === entry.label ? 'page' : undefined}
                >
                  {entry.label}
                </a>
              )
            )
          }
          <a class="nav-contribute" href="/about#contribute">Contribute</a>
        </nav>

        <label class="nav-backdrop" for="nav-toggle" aria-hidden="true"></label>

        <div class="header-actions">
          <a class="icon-btn" href="/search" aria-label="Search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <circle cx="11" cy="11" r="7" />
              <path d="m20 20-3.5-3.5" />
            </svg>
          </a>
          <button class="icon-btn theme-toggle" type="button" aria-label="Switch theme">
            <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" />
            </svg>
            <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4.5" />
              <path d="M12 2.5v2.2M12 19.3v2.2M2.5 12h2.2M19.3 12h2.2M5.2 5.2l1.6 1.6M17.2 17.2l1.6 1.6M18.8 5.2l-1.6 1.6M6.8 17.2l-1.6 1.6" />
            </svg>
          </button>
          <label
            for="nav-toggle"
            class="nav-hamburger"
            aria-label="Menu"
            aria-expanded="false"
            role="button"
            tabindex="0"
          >
            <span class="bars" aria-hidden="true"></span>
          </label>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-col footer-about">
            <a class="footer-brand" href="/">Mission Sikhism</a>
            <p>
              A non-profit, community-built history of the Sikh faith, 1469 to
              today. Every fact on this site is tied to a citation — enforced at
              build time, offered freely in the spirit of <em>sarbat da bhala</em>.
            </p>
          </div>
          <div class="footer-col">
            <h4>Explore</h4>
            <ul>
              <li><a href="/history">History</a></li>
              <li><a href="/map">Global Map</a></li>
              <li><a href="/people">People</a></li>
              <li><a href="/places">Places</a></li>
              <li><a href="/search">Search</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Learn</h4>
            <ul>
              <li><a href="/faith">The Faith</a></li>
              <li><a href="/culture">Culture &amp; Heritage</a></li>
              <li><a href="/glossary">Glossary</a></li>
              <li><a href="/nitnem">Daily Prayers</a></li>
              <li><a href="/library">Library</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <span>© {year} Mission Sikhism · Every fact sourced</span>
          <span>
            <a href="/about#contribute">Contribute</a> · <a href="/rss.xml">RSS</a>
          </span>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        // ---- Theme toggle ----
        var toggleBtn = document.querySelector('.theme-toggle');
        var themeMeta = document.querySelector('meta[name="theme-color"]');
        function applyTheme(t, persist) {
          document.documentElement.setAttribute('data-theme', t);
          if (themeMeta) themeMeta.setAttribute('content', t === 'dark' ? '#0e1013' : '#faf8f3');
          if (persist) {
            try { localStorage.setItem('theme', t); } catch (e) {}
          }
          document.dispatchEvent(new CustomEvent('themechange', { detail: { theme: t } }));
        }
        // Sync the meta colour with whatever the pre-paint script chose.
        applyTheme(document.documentElement.getAttribute('data-theme') || 'light', false);
        if (toggleBtn) {
          toggleBtn.addEventListener('click', function () {
            var next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            applyTheme(next, true);
          });
        }
        // Follow OS changes unless the visitor has picked a theme explicitly.
        try {
          window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function (e) {
            var stored = null;
            try { stored = localStorage.getItem('theme'); } catch (err) {}
            if (stored !== 'light' && stored !== 'dark') applyTheme(e.matches ? 'dark' : 'light', false);
          });
        } catch (e) {}

        // ---- Mobile nav ----
        var toggle = document.getElementById('nav-toggle');
        var hamburger = document.querySelector('.nav-hamburger');
        var nav = document.getElementById('primary-nav');
        if (!toggle || !hamburger || !nav) return;

        function firstLink() {
          return nav.querySelector('a, summary');
        }
        toggle.addEventListener('change', function () {
          var open = toggle.checked;
          hamburger.setAttribute('aria-expanded', open ? 'true' : 'false');
          hamburger.setAttribute('aria-label', open ? 'Close menu' : 'Menu');
          document.body.style.overflow = open ? 'hidden' : '';
          if (open) {
            var f = firstLink();
            if (f) f.focus();
          }
        });
        // Let the hamburger label be toggled with Enter/Space (it is focusable).
        hamburger.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            toggle.checked = !toggle.checked;
            toggle.dispatchEvent(new Event('change'));
          }
        });
        function closeMenu() {
          if (toggle.checked) {
            toggle.checked = false;
            toggle.dispatchEvent(new Event('change'));
            hamburger.focus();
          }
        }
        // Close the mobile panel when a link inside it is followed.
        nav.addEventListener('click', function (e) {
          if (e.target.closest('a') && toggle.checked) closeMenu();
        });

        // Desktop dropdowns: open on hover, close on outside-click and Esc.
        var groups = Array.prototype.slice.call(nav.querySelectorAll('.nav-group'));
        var hoverCapable = window.matchMedia('(hover: hover) and (min-width: 861px)');
        groups.forEach(function (g) {
          g.addEventListener('mouseenter', function () {
            if (hoverCapable.matches) g.open = true;
          });
          g.addEventListener('mouseleave', function () {
            if (hoverCapable.matches) g.open = false;
          });
        });
        document.addEventListener('click', function (e) {
          groups.forEach(function (g) {
            if (g.open && !g.contains(e.target)) g.open = false;
          });
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') {
            groups.forEach(function (g) { g.open = false; });
            closeMenu();
          }
        });
      })();
    </script>
  </body>
</html>
