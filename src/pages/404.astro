---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found — Mission Sikhism"
  description="That page could not be found. Browse the history, map, people, and faith instead."
>
  <section class="section">
    <div class="container">
      <p class="years">Error 404</p>
      <h1>That page wandered off</h1>
      <p class="lede">
        We couldn't find the page you were looking for. It may have moved, or the
        link may be mistaken. Here are the ways back in:
      </p>
      <ul class="lens-grid">
        <li class="lens-card">
          <h3><a href="/history">History</a></h3>
          <p>The story across six eras, 1469 to today.</p>
        </li>
        <li class="lens-card lens-card--map">
          <h3><a href="/map">Map</a></h3>
          <p>Every event plotted where it happened.</p>
        </li>
        <li class="lens-card">
          <h3><a href="/people">People</a></h3>
          <p>The Gurus and figures who shaped the faith.</p>
        </li>
        <li class="lens-card">
          <h3><a href="/faith">The Faith</a></h3>
          <p>The beliefs, practices, and values of Sikhi.</p>
        </li>
        <li class="lens-card">
          <h3><a href="/places">Places</a></h3>
          <p>Locations where the history unfolded.</p>
        </li>
        <li class="lens-card">
          <h3><a href="/search">Search</a></h3>
          <p>Find any event, person, place, or topic.</p>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
