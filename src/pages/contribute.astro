---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contribute — Mission Sikhism" description="How to contribute sourced content to Mission Sikhism.">
  <section class="section">
    <div class="container">
      <h1>Contribute</h1>
      <p>
        Mission Sikhism is community-built and every fact must be sourced. To
        contribute, submit a change with a citation and a maintainer will review
        it before it goes live.
      </p>
      <p>Full contributor guide coming soon.</p>
    </div>
  </section>
</BaseLayout>
