---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SourceList from '../../components/SourceList.astro';
import LastUpdated from '../../components/LastUpdated.astro';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((event) => ({ params: { id: event.id }, props: { event } }));
}

const { event } = Astro.props;
const { Content } = await render(event);
const allEvents = await getCollection('events');

// Resolve linked era, place, and people references.
const eras = await getCollection('eras');
const era = eras.find((e) => e.id === event.data.era.id);

const places = await getCollection('places');
const place = event.data.place
  ? places.find((p) => p.id === event.data.place.id)
  : undefined;

const allPeople = await getCollection('people');
const people = (event.data.people ?? [])
  .map((ref) => allPeople.find((p) => p.id === ref.id))
  .filter((p) => p !== undefined);

// Linked faith topics.
const faithTopics = await getCollection('faith');
const linkedFaith = (event.data.faith ?? [])
  .map((ref) => faithTopics.find((t) => t.id === ref.id))
  .filter((t) => t !== undefined);

// Related events — walk the edge both ways so it's bidirectional.
const relatedIds = new Set((event.data.relatedEvents ?? []).map((r) => r.id));
for (const other of allEvents) {
  if ((other.data.relatedEvents ?? []).some((r) => r.id === event.id)) {
    relatedIds.add(other.id);
  }
}
relatedIds.delete(event.id);
const relatedEvents = [...relatedIds]
  .map((id) => allEvents.find((e) => e.id === id))
  .filter((e) => e !== undefined)
  .sort((a, b) => a.data.year - b.data.year);

const placeLabel = place?.data.name ?? event.data.location;

// Coordinate resolution for structured data.
const hasOwn = typeof event.data.lat === 'number' && typeof event.data.lng === 'number';
const lat = hasOwn ? event.data.lat : place?.data.lat;
const lng = hasOwn ? event.data.lng : place?.data.lng;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const home = new URL('/', Astro.site).href;
const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: event.data.title,
    startDate: String(event.data.year),
    description: event.data.summary,
    url: canonical,
    ...(place || placeLabel
      ? {
          location: {
            '@type': 'Place',
            name: placeLabel,
            ...(typeof lat === 'number' && typeof lng === 'number'
              ? { geo: { '@type': 'GeoCoordinates', latitude: lat, longitude: lng } }
              : {}),
          },
        }
      : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: home },
      { '@type': 'ListItem', position: 2, name: 'History', item: new URL('/history', Astro.site).href },
      ...(era ? [{ '@type': 'ListItem', position: 3, name: era.data.title, item: new URL(`/history/${era.id}`, Astro.site).href }] : []),
      { '@type': 'ListItem', position: era ? 4 : 3, name: event.data.title, item: canonical },
    ],
  },
];
---

<BaseLayout title={`${event.data.title} — Mission Sikhism`} description={event.data.summary}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
  <article class="section">
    <div class="container">
      <nav class="crumb" aria-label="Breadcrumb">
        <a href="/">Home</a> › <a href="/history">History</a> ›
        {era && (<><a href={`/history/${era.id}`}>{era.data.title}</a> › </>)}
        <span aria-current="page">{event.data.title}</span>
      </nav>

      <p class="years">
        {event.data.date ?? event.data.year}
        {event.data.location ? ` · ${event.data.location}` : ''}
      </p>
      <h1>{event.data.title}</h1>
      <p>{event.data.summary}</p>

      <Content />

      <p class="event-meta">
        {placeLabel && (
          <>
            Place:{' '}
            {place ? <a href={`/places/${place.id}`}>{placeLabel}</a> : placeLabel}
          </>
        )}
        {era && (
          <>
            {placeLabel ? ' · ' : ''}Era:{' '}
            <a href={`/history/${era.id}`}>{era.data.title}</a>
          </>
        )}
        {place && (
          <>
            {' · '}<a href={`/map?place=${place.id}`}>See on the map →</a>
          </>
        )}
      </p>

      {
        people.length > 0 && (
          <p>
            People: {people.map((p, i) => (
              <>
                {i > 0 ? ', ' : ''}
                <a href={`/people/${p!.id}`}>{p!.data.name}</a>
              </>
            ))}
          </p>
        )
      }

      {
        linkedFaith.length > 0 && (
          <p>
            The Faith: {linkedFaith.map((t, i) => (
              <>
                {i > 0 ? ', ' : ''}
                <a href={`/faith/${t!.id}`}>{t!.data.title}</a>
              </>
            ))}
          </p>
        )
      }

      {
        relatedEvents.length > 0 && (
          <>
            <h2>Related events</h2>
            <ul>
              {relatedEvents.map((e) => (
                <li>
                  <a href={`/events/${e!.id}`}>
                    <strong>{e!.data.year}</strong> — {e!.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </>
        )
      }

      <LastUpdated path={`src/content/events/${event.id}.md`} />

      <SourceList sources={event.data.sources} />
    </div>
  </article>
</BaseLayout>
