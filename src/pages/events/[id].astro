---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SourceList from '../../components/SourceList.astro';
import LastUpdated from '../../components/LastUpdated.astro';
import ChronicleRibbon from '../../components/ChronicleRibbon.astro';
import { correctionUrl } from '../../site.config';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((event) => ({ params: { id: event.id }, props: { event } }));
}

const { event } = Astro.props;
const { Content } = await render(event);
const allEvents = await getCollection('events');

// Resolve linked era, place, and people references.
const eras = await getCollection('eras');
const era = eras.find((e) => e.id === event.data.era.id);

const places = await getCollection('places');
const place = event.data.place
  ? places.find((p) => p.id === event.data.place.id)
  : undefined;

const allPeople = await getCollection('people');
const people = (event.data.people ?? [])
  .map((ref) => allPeople.find((p) => p.id === ref.id))
  .filter((p) => p !== undefined);

// Linked faith topics.
const faithTopics = await getCollection('faith');
const linkedFaith = (event.data.faith ?? [])
  .map((ref) => faithTopics.find((t) => t.id === ref.id))
  .filter((t) => t !== undefined);

// Related events — walk the edge both ways so it's bidirectional.
const relatedIds = new Set((event.data.relatedEvents ?? []).map((r) => r.id));
for (const other of allEvents) {
  if ((other.data.relatedEvents ?? []).some((r) => r.id === event.id)) {
    relatedIds.add(other.id);
  }
}
relatedIds.delete(event.id);
const relatedEvents = [...relatedIds]
  .map((id) => allEvents.find((e) => e.id === id))
  .filter((e) => e !== undefined)
  .sort((a, b) => a.data.year - b.data.year);

const placeLabel = place?.data.name ?? event.data.location;

// The chronicle: every event is a page in one continuous story. Work out
// where this entry sits in it, and which entries come before and after.
const chronology = allEvents
  .slice()
  .sort((a, b) => a.data.year - b.data.year || a.data.title.localeCompare(b.data.title));
const chronIndex = chronology.findIndex((e) => e.id === event.id);
const prevEvent = chronIndex > 0 ? chronology[chronIndex - 1] : undefined;
const nextEvent = chronIndex < chronology.length - 1 ? chronology[chronIndex + 1] : undefined;

// Coordinate resolution for structured data.
const hasOwn = typeof event.data.lat === 'number' && typeof event.data.lng === 'number';
const lat = hasOwn ? event.data.lat : place?.data.lat;
const lng = hasOwn ? event.data.lng : place?.data.lng;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const home = new URL('/', Astro.site).href;
const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: event.data.title,
    startDate: String(event.data.year),
    description: event.data.summary,
    url: canonical,
    ...(place || placeLabel
      ? {
          location: {
            '@type': 'Place',
            name: placeLabel,
            ...(typeof lat === 'number' && typeof lng === 'number'
              ? { geo: { '@type': 'GeoCoordinates', latitude: lat, longitude: lng } }
              : {}),
          },
        }
      : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: home },
      { '@type': 'ListItem', position: 2, name: 'History', item: new URL('/history', Astro.site).href },
      ...(era ? [{ '@type': 'ListItem', position: 3, name: era.data.title, item: new URL(`/history/${era.id}`, Astro.site).href }] : []),
      { '@type': 'ListItem', position: era ? 4 : 3, name: event.data.title, item: canonical },
    ],
  },
];
---

<BaseLayout title={`${event.data.title} — Mission Sikhism`} description={event.data.summary}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
  <article class="section reading-page" style={era?.data.color ? `--era: ${era.data.color}` : undefined}>
    <div class="container">
      <nav class="crumb" aria-label="Breadcrumb">
        <a href="/">Home</a> › <a href="/history">History</a> ›
        {era && (<><a href={`/history/${era.id}`}>{era.data.title}</a> › </>)}
        <span aria-current="page">{event.data.title}</span>
      </nav>

      <!-- Where this entry sits in the 550-year chronicle -->
      <ChronicleRibbon
        markYear={event.data.year}
        showTicks
        caption={`Entry ${chronIndex + 1} of ${chronology.length} in the chronicle · ${event.data.year}`}
      />

      <div class="reading-layout">
        <div class="reading-main">
          {era && (
            <a class="entry-era-label" href={`/history/${era.id}`}>
              {era.data.shortName ?? era.data.title}
            </a>
          )}
          <h1>{event.data.title}</h1>
          <p class="entry-dateline">
            {event.data.date ?? event.data.year}
            {event.data.location ? ` · ${event.data.location}` : ''}
          </p>
          <p class="entry-lede">{event.data.summary}</p>

          <div class="entry-body">
            <Content />
          </div>

          <div class="entry-end" aria-hidden="true"><span>☬</span></div>

          {
            relatedEvents.length > 0 && (
              <>
                <h2>Cross-references</h2>
                <ul class="xref-list">
                  {relatedEvents.map((e) => (
                    <li>
                      <a href={`/events/${e!.id}`}>
                        <span class="xref-year">{e!.data.year}</span>
                        {e!.data.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            )
          }

          <!-- Turn the page: read the chronicle in order -->
          <nav class="page-turn" aria-label="Previous and next in time">
            {
              prevEvent ? (
                <a class="turn prev" href={`/events/${prevEvent.id}`}>
                  <span class="turn-label">← Earlier</span>
                  <span class="turn-year">{prevEvent.data.year}</span>
                  <span class="turn-title">{prevEvent.data.title}</span>
                </a>
              ) : (
                <span />
              )
            }
            {
              nextEvent ? (
                <a class="turn next" href={`/events/${nextEvent.id}`}>
                  <span class="turn-label">Later →</span>
                  <span class="turn-year">{nextEvent.data.year}</span>
                  <span class="turn-title">{nextEvent.data.title}</span>
                </a>
              ) : (
                <span />
              )
            }
          </nav>

          <LastUpdated path={`src/content/events/${event.id}.md`} />
        </div>

        <aside class="reading-aside">
          <div class="catalog-card">
            <div class="card-head">Catalog card</div>
            <dl>
              <dt>Date</dt>
              <dd>{event.data.date ?? event.data.year}</dd>
              {placeLabel && (
                <>
                  <dt>Place</dt>
                  <dd>{place ? <a href={`/places/${place.id}`}>{placeLabel}</a> : placeLabel}</dd>
                </>
              )}
              {era && (
                <>
                  <dt>Era</dt>
                  <dd><a href={`/history/${era.id}`}>{era.data.title}</a></dd>
                </>
              )}
              {people.length > 0 && (
                <>
                  <dt>People</dt>
                  <dd>
                    {people.map((p, i) => (
                      <>
                        {i > 0 ? ', ' : ''}
                        <a href={`/people/${p!.id}`}>{p!.data.name}</a>
                      </>
                    ))}
                  </dd>
                </>
              )}
              {linkedFaith.length > 0 && (
                <>
                  <dt>The Faith</dt>
                  <dd>
                    {linkedFaith.map((t, i) => (
                      <>
                        {i > 0 ? ', ' : ''}
                        <a href={`/faith/${t!.id}`}>{t!.data.title}</a>
                      </>
                    ))}
                  </dd>
                </>
              )}
            </dl>
            {place && (
              <a class="card-map-link" href={`/map?place=${place.id}`}>See on the map →</a>
            )}
            <a
              class="card-map-link"
              href={correctionUrl(event.data.title, `src/content/events/${event.id}.md`)}
              rel="noopener noreferrer"
              target="_blank"
            >Suggest a correction →</a>
          </div>

          <SourceList sources={event.data.sources} />
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>
