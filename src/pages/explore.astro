---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const people = (await getCollection('people')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
---

<BaseLayout title="Explore — Mission Sikhism" description="People, culture, and heritage of the Sikh tradition.">
  <section class="section">
    <div class="container">
      <h1>Explore</h1>
      <h2>People</h2>
      <ul>
        {
          people.map((p) => (
            <li>
              <a href={`/people/${p.id}`}>{p.data.name}</a>
              {p.data.role ? ` — ${p.data.role}` : ''}
            </li>
          ))
        }
      </ul>
      <h2>Culture &amp; Heritage</h2>
      <p>Coming soon.</p>
    </div>
  </section>
</BaseLayout>
