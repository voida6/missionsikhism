---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SourceList from '../../components/SourceList.astro';
import LastUpdated from '../../components/LastUpdated.astro';

export async function getStaticPaths() {
  const eras = await getCollection('eras');
  return eras.map((era) => ({ params: { id: era.id }, props: { era } }));
}

const { era } = Astro.props;
const { Content } = await render(era);

// Events belonging to this era, oldest first — same files that drive the map.
const events = (await getCollection('events'))
  .filter((e) => e.data.era.id === era.id)
  .sort((a, b) => a.data.year - b.data.year);

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'History', item: new URL('/history', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: era.data.title, item: canonical },
  ],
};
---

<BaseLayout title={`${era.data.title} — Mission Sikhism`} description={era.data.summary}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
  <article class="section">
    <div class="container">
      <nav class="crumb" aria-label="Breadcrumb">
        <a href="/">Home</a> › <a href="/history">History</a> ›
        <span aria-current="page">{era.data.title}</span>
      </nav>
      <p class="years">
        {era.data.startYear}{era.data.endYear ? `–${era.data.endYear}` : '–present'}
      </p>
      <h1>{era.data.title}</h1>
      <p>{era.data.summary}</p>

      <Content />

      <p class="event-meta">
        <a href={`/map?era=${era.id}`}>See this era on the map →</a>
      </p>

      {
        events.length > 0 && (
          <>
            <h2>Events in this era</h2>
            <ul>
              {events.map((e) => (
                <li>
                  <a href={`/events/${e.id}`}>
                    <strong>{e.data.year}</strong> — {e.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </>
        )
      }

      <LastUpdated path={`src/content/eras/${era.id}.md`} />

      <SourceList sources={era.data.sources} />
    </div>
  </article>
</BaseLayout>
