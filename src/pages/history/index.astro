---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const eras = (await getCollection('eras')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="History — Mission Sikhism"
  description="The history of the Sikh faith across six eras, 1469 to today."
>
  <section class="section">
    <div class="container">
      <h1>History</h1>
      <p>The story of the Sikh faith, from 1469 to today, across six eras.</p>
      <ul class="era-list">
        {
          eras.map((era) => (
            <li class="era-card">
              <h3>
                <a href={`/history/${era.id}`}>{era.data.title}</a>
              </h3>
              <p class="years">
                {era.data.startYear}
                {era.data.endYear ? `–${era.data.endYear}` : '–present'}
              </p>
              <p>{era.data.summary}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
