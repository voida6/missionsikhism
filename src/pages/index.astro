---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Everything on the homepage is generated from the content collections, so it
// stays true as content grows.
const eras = (await getCollection('eras')).sort((a, b) => a.data.order - b.data.order);
const events = (await getCollection('events')).sort((a, b) => a.data.year - b.data.year);
const people = await getCollection('people');
const faith = await getCollection('faith');
const places = await getCollection('places');
const culture = await getCollection('culture');
const glossary = await getCollection('glossary');
const nitnem = await getCollection('nitnem');

const eraCount = eras.length;
const eventCount = events.length;
const peopleCount = people.length;
const placeCount = places.length;

// Count unique sources across everything, mirroring the Library.
const seen = new Set<string>();
for (const coll of [eras, events, people, faith, places, culture]) {
  for (const e of coll) {
    for (const s of (e.data as any).sources ?? []) {
      seen.add(`${(s.author ?? '').toLowerCase()}|${s.title.toLowerCase()}`);
    }
  }
}
const sourceCount = seen.size;

// Featured entries laid out on the reading table, spread across the timeline.
const featuredSlugs = ['creation-of-the-khalsa', 'installation-of-adi-granth', 'kartarpur-corridor-opens'];
const featuredEvents = featuredSlugs
  .map((slug) => events.find((e) => e.id === slug))
  .filter((e): e is (typeof events)[number] => Boolean(e));

// The index of people: the Gurus in order, then everyone else.
const gurus = people
  .filter((p) => p.data.category === 'guru')
  .sort((a, b) => (a.data.born ?? 0) - (b.data.born ?? 0));

const span = `${events[0]?.data.year ?? 1469}–${events[events.length - 1]?.data.year ?? new Date().getFullYear()}`;
---

<BaseLayout
  title="Mission Sikhism — A Sourced History of the Sikh Faith"
  description="A non-profit, fully-sourced history of the Sikh faith, from 1469 to today. Every fact is cited."
>
  <!-- The front desk: search first, a librarian beside it -->
  <section class="catalog-hero">
    <div class="container">
      <p class="ik-onkar" aria-hidden="true">ੴ</p>
      <h1>A library of Sikh history</h1>
      <p class="lede">
        Non-profit and community-built — the history of the Sikh faith,
        {span}, where every fact is tied to a citation.
      </p>

      <form class="catalog-search" action="/search" method="get" role="search">
        <input
          type="search"
          name="q"
          placeholder="Search the catalog — try “Khalsa”, “Amritsar”, “langar”"
          aria-label="Search the site"
        />
        <button type="submit">Search</button>
      </form>

      <div class="start-here">
        <span class="start-label">New here? Follow a path:</span>
        <a href="/paths/five-centuries-in-ten-entries">Five centuries in 10 entries</a>
        <a href="/paths/the-ten-gurus">The Ten Gurus</a>
        <a href="/paths/partition-and-the-diaspora">Partition &amp; the diaspora</a>
      </div>
    </div>
  </section>

  <!-- The colophon: the promise in one line, backed by live numbers -->
  <div class="colophon-band">
    <div class="container">
      <p>
        <strong>{eraCount}</strong> eras · <strong>{eventCount}</strong> events ·
        <strong>{peopleCount}</strong> people · <strong>{placeCount}</strong> places —
        every entry cited against <a href="/library"><strong>{sourceCount}</strong> sources</a>.
      </p>
    </div>
  </div>

  <!-- The shelf: six eras as spines -->
  <section class="section">
    <div class="container">
      <span class="kicker">The shelf</span>
      <div class="section-head-row">
        <h2 class="section-title">Six volumes, {span}</h2>
        <a class="section-link" href="/history">Read the full history →</a>
      </div>
      <p class="section-sub">
        From Guru Nanak's birth to the global community of today — take a volume
        down. Each era keeps its colour on the map and everywhere else.
      </p>
      <div class="bookshelf">
        {
          eras.map((era) => (
            <a class="book-spine" href={`/history/${era.id}`} style={`--era: ${era.data.color}`}>
              <div class="spine-inner">
                <div>
                  <span class="spine-order">Vol. {era.data.order}</span>
                  <h3>{era.data.title.replace(/^Era \d+ — /, '')}</h3>
                </div>
                <span class="spine-years">
                  {era.data.startYear}{era.data.endYear ? `–${era.data.endYear}` : '–present'}
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Featured entries: three good first reads -->
  <section class="section">
    <div class="container">
      <span class="kicker">Featured entries</span>
      <div class="section-head-row">
        <h2 class="section-title">Three good places to begin</h2>
        <a class="section-link" href="/map">See every event on the map →</a>
      </div>
      <p class="section-sub">
        A defining moment from the beginning, the middle, and the living memory
        of the story — each one a doorway into its era.
      </p>
      <ul class="excerpt-list">
        {
          featuredEvents.map((e) => (
            <li class="excerpt-card">
              <span class="excerpt-meta">
                <span class="yr">{e.data.year}</span>
                {e.data.location}
              </span>
              <h3><a href={`/events/${e.id}`}>{e.data.title}</a></h3>
              <p>{e.data.summary}</p>
              <span class="excerpt-src">
                {e.data.sources.length} {e.data.sources.length === 1 ? 'source' : 'sources'} cited
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- The index of people -->
  <section class="section">
    <div class="container">
      <span class="kicker">The index of people</span>
      <div class="section-head-row">
        <h2 class="section-title">The ten Gurus, and those who followed</h2>
        <a class="section-link" href="/people">All {peopleCount} people →</a>
      </div>
      <p class="section-sub">
        Five centuries of the faith, told through the people who carried it.
      </p>
      <ul class="name-index">
        {gurus.map((p) => (
          <li><a href={`/people/${p.id}`}>{p.data.name}</a></li>
        ))}
        <li class="index-more"><a href="/people">Browse all people →</a></li>
      </ul>
    </div>
  </section>

  <!-- The card catalog: every drawer in the room -->
  <section class="section">
    <div class="container">
      <span class="kicker">The card catalog</span>
      <h2 class="section-title">Browse by drawer</h2>
      <p class="section-sub">
        History is half the picture. The beliefs, culture, language, and daily
        practice of Sikhi — each drawer sourced like everything else.
      </p>
      <ul class="drawer-grid">
        <li class="drawer">
          <div class="drawer-pull"><h3><a href="/map">Global Map</a></h3><span class="drawer-count">{eventCount} events</span></div>
          <p>Every event plotted where it happened — filter by era, type, or person.</p>
        </li>
        <li class="drawer">
          <div class="drawer-pull"><h3><a href="/places">Places</a></h3><span class="drawer-count">{placeCount}</span></div>
          <p>The cities, gurdwaras, and battlefields where the history happened.</p>
        </li>
        <li class="drawer">
          <div class="drawer-pull"><h3><a href="/faith">The Faith</a></h3><span class="drawer-count">{faith.length} topics</span></div>
          <p>Core beliefs, practices, and values — from One God to the Rehat Maryada.</p>
        </li>
        <li class="drawer">
          <div class="drawer-pull"><h3><a href="/culture">Culture &amp; Heritage</a></h3><span class="drawer-count">{culture.length} topics</span></div>
          <p>Sacred music, langar, language and script, and a global community.</p>
        </li>
        <li class="drawer">
          <div class="drawer-pull"><h3><a href="/glossary">Glossary</a></h3><span class="drawer-count">{glossary.length} terms</span></div>
          <p>Key terms with Gurmukhi, transliteration, and plain definitions.</p>
        </li>
        <li class="drawer">
          <div class="drawer-pull"><h3><a href="/nitnem">Daily Prayers</a></h3><span class="drawer-count">{nitnem.length} banis</span></div>
          <p>The nitnem — the banis a Sikh reads each day, with a sourced note on each.</p>
        </li>
        <li class="drawer">
          <div class="drawer-pull"><h3><a href="/library">Library</a></h3><span class="drawer-count">{sourceCount} sources</span></div>
          <p>Every work this site cites, gathered in one bibliography.</p>
        </li>
        <li class="drawer">
          <div class="drawer-pull"><h3><a href="/books">Books to Read</a></h3></div>
          <p>Where to go deeper — recommended reading, from first book to full shelf.</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- Contribute -->
  <section class="contribute-band">
    <div class="container">
      <div class="inner">
        <h2>Help build this library</h2>
        <p>
          Spotted an inaccuracy? Know a stronger source, or an event not yet
          documented? This project grows as research grows — every suggestion
          needs only one thing: a citation.
        </p>
        <p class="hero-actions" style="justify-content: center;">
          <a class="btn btn-primary" href="/about#contribute">How to contribute</a>
          <a class="btn" href="/library">Browse the sources</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
