---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// The Library is the citation rule turned into a feature. We gather every
// source cited across the site, dedupe them, and cross-reference the canonical
// `works` bibliography (Phase I) so each recurring source is shown once with a
// count of how many entries cite it. Pagefind adds full-site search on top.
const sourced = ['eras', 'places', 'events', 'people', 'faith', 'culture'] as const;

type Src = {
  title: string; author?: string; publisher?: string;
  year?: number; url?: string; page?: string; note?: string;
};

const norm = (s: string) => s.trim().toLowerCase();

// Count how many content entries cite each unique source (by author|title|year).
const seen = new Map<string, Src>();
const citeCount = new Map<string, number>();
for (const name of sourced) {
  const entries = await getCollection(name as any);
  for (const entry of entries) {
    for (const s of (entry.data.sources ?? []) as Src[]) {
      const key = `${norm(s.author ?? '')}|${norm(s.title)}|${s.year ?? ''}`;
      if (!seen.has(key)) seen.set(key, s);
      citeCount.set(norm(s.title), (citeCount.get(norm(s.title)) ?? 0) + 1);
    }
  }
}

const works = (await getCollection('works')).sort((a, b) =>
  (a.data.author ?? a.data.title).localeCompare(b.data.author ?? b.data.title)
);
const workTitles = new Set(works.map((w) => norm(w.data.title)));

// Sources that are NOT already represented by a canonical work.
const sortKey = (s: Src) => norm(s.author ?? s.title);
const otherSources = [...seen.values()]
  .filter((s) => !workTitles.has(norm(s.title)))
  .sort((a, b) => sortKey(a).localeCompare(sortKey(b)));

const totalUnique = works.length + otherSources.length;
---

<BaseLayout
  title="Library — Mission Sikhism"
  description="Search the whole site, and browse every source cited across it in one bibliography."
>
  <link is:inline rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <section class="section">
    <div class="container">
      <span class="kicker">Every fact sourced</span>
      <h1>Library</h1>
      <p class="lede">
        Every claim on this site is tied to a citation, enforced at build time.
        Search the whole site below, or browse the {totalUnique} unique
        source{totalUnique === 1 ? '' : 's'} — the canonical works we lean on
        most, then everything else cited across the site. Looking for where to
        start? See <a href="/books">Books to Read</a>.
      </p>

      <div id="search" class="pf-search"></div>

      <h2 class="library-heading">Canonical works</h2>
      <ol class="library-list">
        {
          works.map((w) => {
            const n = citeCount.get(norm(w.data.title)) ?? 0;
            return (
              <li>
                {w.data.author && <span>{w.data.author}. </span>}
                {w.data.url ? (
                  <a href={w.data.url} rel="noopener noreferrer" target="_blank"><cite>{w.data.title}</cite></a>
                ) : (
                  <cite>{w.data.title}</cite>
                )}
                {w.data.publisher && <span>. {w.data.publisher}</span>}
                {w.data.year && <span> ({w.data.year})</span>}
                {n > 0 && <span class="cite-count"> · cited by {n} {n === 1 ? 'entry' : 'entries'}</span>}
                {w.data.recommended && <span class="cite-count"> · <a href="/books">recommended</a></span>}
                <span>.</span>
              </li>
            );
          })
        }
      </ol>

      {
        otherSources.length > 0 && (
          <>
            <h2 class="library-heading">Other sources cited</h2>
            <ol class="library-list">
              {otherSources.map((s) => (
                <li>
                  {s.author && <span>{s.author}. </span>}
                  {s.url ? (
                    <a href={s.url} rel="noopener noreferrer" target="_blank"><cite>{s.title}</cite></a>
                  ) : (
                    <cite>{s.title}</cite>
                  )}
                  {s.publisher && <span>. {s.publisher}</span>}
                  {s.year && <span> ({s.year})</span>}
                  {s.note && <span> — {s.note}</span>}
                  <span>.</span>
                </li>
              ))}
            </ol>
          </>
        )
      }
    </div>
  </section>

  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', function () {
      if (window.PagefindUI) {
        new PagefindUI({ element: '#search', showSubResults: true, showImages: false, resetStyles: false });
      }
    });
  </script>

  <!-- Pagefind theming (light + dark) lives in global.css under `.pf-search`. -->
  <style is:global>
    .pf-search { margin-bottom: 2.25rem; }
  </style>
</BaseLayout>
