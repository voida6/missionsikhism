---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// The WHO lens. The ten Gurus render as a compact gallery (one line each, in
// succession order) so the rest of the index — martyrs, generals, rulers —
// is visible without a long scroll. Within a section, sort by birth year
// where known, then name so undated figures stay in stable order.
const people = await getCollection('people');

const categoryLabels = {
  guru: 'Gurus',
  martyr: 'Martyrs',
  general: 'Generals & Commanders',
  ruler: 'Rulers',
  reformer: 'Reformers',
  scholar: 'Scholars',
  saint: 'Saints',
  'modern-figure': 'Modern Figures',
  other: 'Others',
};

const byBirthThenName = (a, b) => {
  const ay = a.data.born ?? 9999;
  const by = b.data.born ?? 9999;
  if (ay !== by) return ay - by;
  return a.data.name.localeCompare(b.data.name);
};

const groups = Object.keys(categoryLabels)
  .map((cat) => ({
    cat,
    label: categoryLabels[cat],
    items: people.filter((p) => p.data.category === cat).sort(byBirthThenName),
  }))
  .filter((g) => g.items.length > 0);

const gurus = groups.find((g) => g.cat === 'guru')?.items ?? [];
const otherGroups = groups.filter((g) => g.cat !== 'guru');
---

<BaseLayout
  title="People — Mission Sikhism"
  description="The Gurus and key figures of Sikh history, grouped by their role, each life tied to the events they shaped."
>
  <section class="section">
    <div class="container">
      <span class="kicker">Who shaped it</span>
      <h1>People</h1>
      <p class="lede">
        The Gurus, generals, rulers, and figures who shaped Sikh history. Each
        life links to the events they appear in — the same events you can see on
        the <a href="/map">map</a> and in the <a href="/history">timeline</a>.
      </p>

      <!-- Jump straight to any section of the index -->
      <nav class="cat-jump" aria-label="Sections">
        {groups.map((g) => <a href={`#${g.cat}`}>{g.label}</a>)}
      </nav>

      {
        gurus.length > 0 && (
          <>
            <h2 id="guru">The Ten Gurus</h2>
            <p class="section-sub">In order of succession, 1469–1708.</p>
            <ol class="guru-gallery">
              {gurus.map((p, i) => (
                <li>
                  <a class="guru-tile" href={`/people/${p.id}`}>
                    <span class="guru-n" aria-hidden="true">{i + 1}</span>
                    <span class="guru-body">
                      <span class="guru-name">{p.data.name}</span>
                      <span class="years">
                        {p.data.born ?? '?'}{p.data.died ? `–${p.data.died}` : ''}
                      </span>
                    </span>
                  </a>
                </li>
              ))}
            </ol>
          </>
        )
      }

      {
        otherGroups.map((group) => (
          <>
            <h2 id={group.cat}>{group.label}</h2>
            <ul class="people-list">
              {group.items.map((p) => (
                <li class="person-card">
                  <div class="person-head">
                    <h3><a href={`/people/${p.id}`}>{p.data.name}</a></h3>
                    <span class="years">
                      {p.data.born ?? '?'}{p.data.died ? `–${p.data.died}` : ''}
                    </span>
                  </div>
                  {p.data.role && <p class="role">{p.data.role}</p>}
                  <p>{p.data.summary}</p>
                </li>
              ))}
            </ul>
          </>
        ))
      }
    </div>
  </section>
</BaseLayout>
